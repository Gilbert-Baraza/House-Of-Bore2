# ─────────────────────────────────────────────────────────────────────────────
# House-Of-Bore — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# This file IS committed to version control. It shows every variable the
# project needs, with placeholders instead of real values.
#
# Setup instructions for new contributors:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values in your new .env file
#   3. Never commit the real .env file
# ─────────────────────────────────────────────────────────────────────────────


# ─── Django Core ──────────────────────────────────────────────────────────────
# Generate a new secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY= '=q)qqgg%ck6lk45k3b#3fdwg6vrsiqrw#-3g##i6(ook)+r_gd'

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

# Options: development | production
DJANGO_ENV=development


# ─── Database (Production — PostgreSQL) ──────────────────────────────────────
# Only required when DJANGO_ENV=production
DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432


# ─── Email (Production — SMTP) ───────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=


# ─── Security (Production only) ──────────────────────────────────────────────
CSRF_TRUSTED_ORIGINS=
