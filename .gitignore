# ─────────────────────────────────────────────────────────────────────────────
# House-Of-Bore — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
# .env.example is ntentionally NOT ignored — it's the safe template for teammates

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ─── Virtual Environment ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Django ───────────────────────────────────────────────────────────────────
db.sqlite3
*.sqlite3

# Collected static files (generated by collectstatic — do not commit)
staticfiles/

# User-uploaded media files (should be stored on external storage in production)
media/

# ─── Node / Tailwind (Phase 1.3) ──────────────────────────────────────────────
node_modules/
npm-debug.log*

# Compiled Tailwind CSS output (generated by `manage.py tailwind build`)
# Regenerated at deploy time — do not commit
theme/static/css/dist/

# npm lock file — commit this if you want reproducible installs on CI
# theme/static_src/package-lock.json

# ─── IDE & OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Testing & Coverage ───────────────────────────────────────────────────────
.coverage
coverage/
htmlcov/
.pytest_cache/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
